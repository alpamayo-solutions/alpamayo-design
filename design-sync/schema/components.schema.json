{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["package", "version", "commit", "generatedAt", "cards"],
    "properties": {
        "package": { "const": "@alpamayo-solutions/design" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "commit": { "type": "string", "minLength": 7 },
        "generatedAt": { "type": "string" },
        "cards": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "path",
                    "group",
                    "type",
                    "title",
                    "component",
                    "sourcePath",
                    "story",
                    "variants",
                    "snippet"
                ],
                "properties": {
                    "path": { "type": "string", "pattern": "^[a-z]+/[a-z0-9-]+\\.html$" },
                    "group": { "enum": ["Foundations", "Components", "Signature"] },
                    "type": { "enum": ["component", "foundation"] },
                    "title": { "type": "string" },
                    "component": { "type": ["string", "null"] },
                    "sourcePath": { "type": "string" },
                    "story": { "type": "string" },
                    "variants": { "type": "array", "items": { "type": "string" } },
                    "snippet": { "type": "string" }
                }
            }
        }
    }
}
